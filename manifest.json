{
  "manifest_version": 3,
  "name": "Deep Work Guardian",
  "version": "1.0",
  "description": "Keeps you away from Reddit when you're in the zone!",
  "permissions": ["tabs", "storage","scripting"],
  "host_permissions": [
    "*://*.reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://*.reddit.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}

